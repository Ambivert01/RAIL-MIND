{
  "name": "railmind",
  "version": "1.0.0",
  "private": true,
  "description": "RailMind - Cognitive Railway Operating System",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "pnpm --filter api exec prisma migrate dev",
    "db:generate": "pnpm --filter api exec prisma generate",
    "db:push": "pnpm --filter api exec prisma db push",
    "db:seed": "pnpm --filter api exec ts-node ../../scripts/seed/index.ts",
    "db:studio": "pnpm --filter api exec prisma studio",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "setup": "pnpm install && pnpm docker:up && sleep 5 && pnpm db:push && pnpm db:seed"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "5.4.5",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": "20.x",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.9"
}
