# ─── DATABASE ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://railmind:railmind_pass@localhost:5432/railmind?schema=public"

# ─── NEO4J ─────────────────────────────────────────────────────────────────────
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="railmind_neo4j"

# ─── QDRANT ─────────────────────────────────────────────────────────────────────
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""

# ─── MINIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="railmind_minio"
MINIO_SECRET_KEY="railmind_minio_secret"
MINIO_BUCKET="railmind-docs"

# ─── REDIS ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── AUTH ──────────────────────────────────────────────────────────────────────
JWT_SECRET="railmind_jwt_secret_change_in_production_super_long_key"
JWT_EXPIRY="7d"
REFRESH_TOKEN_EXPIRY="30d"

# ─── AI PROVIDERS ──────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-your-openai-key-here"
ANTHROPIC_API_KEY="sk-ant-your-anthropic-key-here"

# ─── BACKEND ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── FRONTEND (public vars exposed to browser) ─────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_WS_URL="http://localhost:3001"
NEXT_PUBLIC_MAPBOX_TOKEN="your-mapbox-token-here"
